<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.tikita.bambu</string>
  <!-- caffeinate -s: köprü çalışırken Mac (fişe takılıyken) uykuya dalmaz -->
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/caffeinate</string>
    <string>-s</string>
    <string>/usr/bin/python3</string>
    <string>/Users/KULLANICI_ADIN/tikita/bambu_kopru.py</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/tmp/tikita-bambu.log</string>
  <key>StandardErrorPath</key><string>/tmp/tikita-bambu.log</string>
</dict>
</plist>
