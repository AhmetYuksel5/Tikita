rules_version = '2';
// ============================================================
//  Tikita — Firestore güvenlik kuralları
//  DURUM: Uygulama henüz Firebase Authentication kullanmıyor; istemci
//  anonim bağlanıyor. Bu yüzden "auth gerektiren" kurallar uygulamayı
//  kırar. Aşağıdaki açık kural geçicidir.
//
//  Ara önlem (uygulandı): kullanıcı PIN'leri düz metin değil; tuzlu
//  SHA-256 özet (pinHash/pinSalt) olarak saklanır.
//
//  KALICI ÇÖZÜM (yol haritası):
//   1) Firebase Authentication'ı aç.
//   2) Giriş ekranını Auth ile entegre et.
//   3) Aşağıdaki yorumlu kuralları aç:  firebase deploy --only firestore:rules
//        function signedIn() { return request.auth != null; }
//        match /{document=**} { allow read, write: if signedIn(); }
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {
    // Geçici açık erişim (gerçek auth eklenene kadar).
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2030, 1, 1);
    }
  }
}
